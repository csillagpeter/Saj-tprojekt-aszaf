<Page x:Class="SajatProjekt0._3.sajtablak"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SajatProjekt0._3"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="sajtablak">
    <Grid Background="#FFF4D0">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock 
                x:Name="SajtCimTextBlock"
                Text="Gouda Sajt Részletek" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#5E4300" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBlock 
                x:Name="SajtLeirasTextBlock"
                Text="A Gouda egy híres holland félkemény sajt..." 
                       FontSize="16" 
                       Foreground="#333333"
                       TextWrapping="Wrap"
                       Width="400"/>
        </StackPanel>
    </Grid>


</Page>
